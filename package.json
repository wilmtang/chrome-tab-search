{
  "name": "chrome-tab-search",
  "private": true,
  "scripts": {
    "build": "web-ext build --config web-ext-config.mjs --overwrite-dest",
    "icons": "node scripts/generate-icons.js",
    "lint": "web-ext lint --config web-ext-config.mjs",
    "publish:firefox": "web-ext sign --config web-ext-config.mjs --channel=listed --amo-metadata amo-metadata.json --approval-timeout=0",
    "start": "web-ext run --config web-ext-config.mjs"
  },
  "devDependencies": {
    "web-ext": "^10.3.0"
  }
}
